// 管道聚合：移动平均和导数
GET /sales/_search
{
  "size": 0,
  "aggs": {
    "sales_per_month": {
      "date_histogram": {
        "field": "date",
        "calendar_interval": "month"
      },
      "aggs": {
        "monthly_total": {
          "sum": { "field": "amount" }
        },
        "moving_avg_3": {
          "moving_fn": {
            "buckets_path": "monthly_total",
            "window": 3,
            "script": "MovingFunctions.unweightedAvg(values)"
          }
        },
        "monthly_change": {
          "derivative": { "buckets_path": "monthly_total" }
        }
      }
    }
  }
}